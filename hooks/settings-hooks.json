{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"MEMORY_PATH_PLACEHOLDER/scripts/session-start.js\" \"MEMORY_PATH_PLACEHOLDER\" 2>/dev/null || true",
            "statusMessage": "Loading memory index..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"MEMORY_PATH_PLACEHOLDER/scripts/session-end.js\" \"MEMORY_PATH_PLACEHOLDER\" 2>/dev/null || true",
            "statusMessage": "Consolidating memory..."
          }
        ]
      }
    ]
  }
}
